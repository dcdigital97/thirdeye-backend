# ---- ThirdEye backend configuration ----
# Copy to `.env` and fill in. NEVER commit the real .env (it holds your key).

# Port the Node service listens on (behind Caddy). Leave as 8080 for the compose setup.
PORT=8080

# The domain you point at this server (an A record -> the VPS IP). Caddy gets a TLS cert for it.
# e.g. api.thirdeye.yourdomain.com
BACKEND_DOMAIN=api.example.com

# Which frontend origin(s) may call this backend. Set to your Netlify origin for production;
# "*" is fine while testing. Comma-separate multiple origins.
CORS_ORIGIN=https://thirdeyeeeeeeee.netlify.app

# ---- AIS (AISStream) ----
# Free key from https://aisstream.io/ (sign in with GitHub, then create an API key).
# This lives ONLY here on the server and is never sent to the browser.
AISSTREAM_API_KEY=

# Ingestion bounding box "latMin,lonMin,latMax,lonMax". Default below = NW Europe / North Sea / UK.
# Widen carefully — global ("-90,-180,90,180") is a firehose and heavier on a small box.
AIS_BBOX=40,-20,62,30

# ---- stream fan-out tuning (optional) ----
STREAM_INTERVAL_MS=3000
MAX_VESSELS=800
VESSEL_TTL_SEC=1800
